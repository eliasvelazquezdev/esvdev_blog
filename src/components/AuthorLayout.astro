---
interface Props {
  publishedAt: Date | string;
  updatedAt?: Date | string;
}

const { publishedAt, updatedAt } = Astro.props;

function formatDate(date: Date | string) {
  const dateFormatting = {
    year: "numeric",
    month: "long",
    day: "numeric",
  };

  return new Date(date).toLocaleDateString("es-ES", dateFormatting);
}

const pubDateStr = formatDate(publishedAt);
const upDateStr = updatedAt ? formatDate(updatedAt) : null;
const isUpdated = upDateStr && upDateStr !== pubDateStr;
---

<div
  class="flex items-center space-x-4 border-b border-gray-700 pb-12"
  data-purpose="author-byline"
>
  <img
    alt="Autor: Elias Velázquez"
    class="w-12 h-12 rounded-full grayscale brightness-110 object-cover"
    src="https://res.cloudinary.com/dwczjy8e4/image/upload/v1773862675/esvdev_linkedin_gpt_1_k2tl3z.png"
  />
  <div class="text-sm">
    <p class="font-semibold text-brand-offwhite">Elias Velázquez</p>
    <div class="text-brand-gray flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-2">
      <time datetime={new Date(publishedAt).toISOString()}>Publicado el {pubDateStr}</time>
      {isUpdated && (
        <>
          <span class="hidden sm:inline">•</span>
          <time datetime={new Date(updatedAt!).toISOString()} class="italic text-brand-orange/80">Actualizado el {upDateStr}</time>
        </>
      )}
    </div>
  </div>
</div>
