---
interface Props {
  name: "brain" | "cloud" | "wrench" | "briefcase" | "tags" | "lightning" | "notebook";
  size?: number | string;
  className?: string;
}

const { name, size = 24, className = "" } = Astro.props;

const icons = {
  brain: {
    viewBox: "0 0 24 24",
    paths: [
      { d: "M12 18V5" },
      { d: "M15 13a4.17 4.17 0 0 1-3-4 4.17 4.17 0 0 1-3 4" },
      { d: "M17.598 6.5A3 3 0 1 0 12 5a3 3 0 1 0-5.598 1.5" },
      { d: "M17.997 5.125a4 4 0 0 1 2.526 5.77" },
      { d: "M18 18a4 4 0 0 0 2-7.464" },
      { d: "M19.967 17.483A4 4 0 1 1 12 18a4 4 0 1 1-7.967-.517" },
      { d: "M6 18a4 4 0 0 1-2-7.464" },
      { d: "M6.003 5.125a4 4 0 0 0-2.526 5.77" },
    ],
  },
  cloud: {
    viewBox: "0 0 24 24",
    paths: [{ d: "M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z" }],
  },
  wrench: {
    viewBox: "0 0 24 24",
    paths: [
      {
        d: "M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z",
      },
    ],
  },
  briefcase: {
    viewBox: "0 0 24 24",
    paths: [
      { d: "M12 12h.01" },
      { d: "M16 6V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" },
      { d: "M22 13a18.15 18.15 0 0 1-20 0" },
    ],
    rects: [{ width: "20", height: "14", x: "2", y: "6", rx: "2" }],
  },
  tags: {
    viewBox: "0 0 24 24",
    paths: [
      { d: "M13.172 2a2 2 0 0 1 1.414.586l6.71 6.71a2.4 2.4 0 0 1 0 3.408l-4.592 4.592a2.4 2 0 0 1-3.408 0l-6.71-6.71A2 2 0 0 1 6 9.172V3a1 1 0 0 1 1-1z" },
      { d: "M2 7v6.172a2 2 0 0 0 .586 1.414l6.71 6.71a2.4 2 0 0 0 3.191.193" },
    ],
    circles: [{ cx: "10.5", cy: "6.5", r: ".5", fill: "currentColor" }],
  },
  lightning: {
    viewBox: "0 0 24 24",
    paths: [
      { d: "M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z" },
    ],
  },
  notebook: {
    viewBox: "0 0 24 24",
    paths: [
      { d: "M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4" },
      { d: "M2 6h4" },
