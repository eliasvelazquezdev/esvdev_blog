      { d: "M2 18h4" },
      { d: "M21.378 5.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z" },
    ],
  },
};

const icon = icons[name as keyof typeof icons] as {
  viewBox: string;
  paths?: { d: string }[];
  rects?: { width: string; height: string; x: string; y: string; rx: string }[];
  circles?: { cx: string; cy: string; r: string; fill?: string }[];
};
---

{
  icon && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width={size}
      height={size}
      viewBox={icon.viewBox}
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={`lucide lucide-${name}-icon ${className}`}
    >
      {icon.paths && icon.paths.map((path) => <path d={path.d} />)}
      {icon.rects && icon.rects.map((rect) => <rect {...rect} />)}
      {icon.circles && icon.circles.map((circle) => <circle {...circle} />)}
    </svg>
  )
}
