---
const links = [
  { label: "Blog", href: "/blog/" },
  { label: "Zips", href: "/blog/zips/" },
  { label: "Tags", href: "/blog/tags/" },
  { label: "Newsletter", href: "/newsletter/" },
  { label: "About", href: "/about/" },
];
---

<nav
  class="max-w-4xl mx-auto px-6 py-12 flex flex-col md:flex-row items-start md:items-center md:justify-between gap-6"
  data-purpose="site-navigation"
>
  <div class="w-full flex items-center justify-between">
    <a class="flex items-center gap-3" href="/">
      <img
        class="w-10 h-10 rounded-full object-cover"
        src="/logo/esvdev_logo_no_under.svg"
        alt="esvdev_logo"
      />
      <span class="text-xl font-semibold tracking-tight uppercase text-brand-orange hidden md:inline">
        El Ingeniero Consciente
      </span>
    </a>
    <button
      id="nav-toggle"
      class="md:hidden inline-flex items-center justify-center rounded-full p-2 hover:bg-white/10 transition-colors text-brand-offwhite"
      type="button"
      aria-controls="site-nav-links"
      aria-expanded="false"
    >
      <span class="sr-only">Abrir menú</span>
      <div class="space-y-1">
        <span class="block w-6 h-0.5 bg-brand-offwhite"></span>
        <span class="block w-6 h-0.5 bg-brand-offwhite"></span>
        <span class="block w-6 h-0.5 bg-brand-offwhite"></span>
      </div>
    </button>
  </div>

  <div
    id="site-nav-links"
    class="hidden md:flex flex-col md:flex-row w-full md:w-auto gap-6 md:gap-6 text-sm font-medium uppercase tracking-widest text-brand-offwhite bg-white/5 md:bg-transparent rounded-xl p-4 md:p-0"
  >
    {links.map((link) => (
      <a class="block w-full md:w-auto py-2 md:py-0 hover:text-brand-orange transition-colors" href={link.href}>
        {link.label}
      </a>
    ))}
  </div>
</nav>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("site-nav-links");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = menu.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", String(isOpen));
    });

    const links = menu.querySelectorAll("a");
    links.forEach((link) => {
      link.addEventListener("click", () => {
        if (!menu.classList.contains("hidden")) {
          menu.classList.add("hidden");
          toggle.setAttribute("aria-expanded", "false");
        }
      });
    });
  }
</script>
