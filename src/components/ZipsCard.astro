---
interface Props {
  zip: {
    title: string;
    excerpt?: string;
    slug?: {
      current?: string;
    };
  };
  className?: string;
}

const { zip, className = "" } = Astro.props as Props;
const slug = zip.slug?.current;
const href = slug ? `/blog/zips/${slug}` : "/blog/zips/";
---

<a
  href={href}
  class={`group block h-full rounded-xl border border-gray-800 bg-white/5 p-5 transition-colors hover:border-brand-orange/50 focus:outline-none focus:ring-2 focus:ring-brand-orange/50 no-underline hover:no-underline focus:no-underline ${className}`}
  aria-label={`Leer zip: ${zip.title}`}
>
  <h3 class="text-lg font-bold text-brand-orange no-underline group-hover:no-underline">
    {zip.title}
  </h3>

  {zip.excerpt && (
    <p class="mt-2 text-sm text-brand-gray">
      {zip.excerpt}
    </p>
  )}
</a>
