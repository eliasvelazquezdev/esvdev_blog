---
import Author from "../../../components/Author.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { components } from '../../../components/PortableTextComponents.jsx';

import { formatDate } from '../../../utils/utils.js';
import { getTagColorClasses } from "../../../utils/tagColors";

import { sanityClient } from "sanity:client";
import { PortableText } from "astro-portabletext";
import type { SanityDocument } from "@sanity/client";

const { slug } = Astro.params;

const ZIP_BY_SLUG_QUERY = `*[
    contentType == "zip" && slug.current == "${slug}"
][0]{
    _id,
    title,
    excerpt,
    publishedAt,
    _updatedAt,
    body,
    "tags": tags[]->{
    name,
    "slug": slug.current,
    color,
    description
    }
}`;

const zip = await sanityClient.fetch<SanityDocument>(ZIP_BY_SLUG_QUERY);
if (!zip) {
    throw new Error(`Zip entry not found for slug: ${slug}`);
}
const portableText = zip.body;

const canonicalURL = new URL(`/blog/zips/${slug}`, Astro.site).href;

---

<BaseLayout pageTitle={zip.title} canonicalURL={canonicalURL}>
    <div class="mb-20">
        <h2 class="text-4xl font-bold mb-3 text-orange-500">
            {zip.title}
        </h2>
        <div class="flex flex-wrap">
            <p class="text-gray-500 mt-1 mb-5 me-2">
                <i class='bx bxs-calendar me-1'></i>
                Publicado:
                {formatDate(zip.publishedAt)}
            </p>
            {
                zip.publishedAt != zip._updatedAt ?
                    <p class="text-gray-500 mt-1  mb-2">
                        | Actualizado:
                        {formatDate(zip._updatedAt)}
                    </p>
                : <div></div>
            }
        </div>
        <div class="text-gray-400">
            {zip.excerpt}
        </div>
    </div>

    <PortableText value={portableText}  components={components} />

    {zip.tags && zip.tags.length > 0 && (
        <div class="mt-8 pt-6">
            <h3 class="text-lg font-semibold mb-4 text-sky-600">Tags:</h3>
            <div class="flex flex-wrap gap-2">
                {zip.tags.map((tag) => {
                    const colors = getTagColorClasses(tag.color);
                    return (
                        <a
                            href={`/blog/tags/${tag.slug}`}
                            class={`inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium ${colors.bg} ${colors.text} ${colors.hover} transition-colors duration-200`}
                            title={tag.description || `Ver todos los posts sobre ${tag.name}`}
                        >
                            #{tag.name}
                        </a>
                    );
                })}
            </div>
        </div>
    )}

    <Author />
</BaseLayout>
