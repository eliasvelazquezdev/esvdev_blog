---
import AuthorLayout from "../../../components/AuthorLayout.astro";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { components } from '../../../components/PortableTextComponents.jsx';


import { getTagColorClasses } from "../../../utils/tagColors";

import { sanityClient } from "sanity:client";
import { PortableText } from "astro-portabletext";
import type { SanityDocument } from "@sanity/client";

const { slug } = Astro.params;

const ZIP_BY_SLUG_QUERY = `*[
    contentType == "zip" && slug.current == "${slug}"
][0]{
    _id,
    title,
    excerpt,
    publishedAt,
    _updatedAt,
    body,
    "tags": tags[]->{
    name,
    "slug": slug.current,
    color,
    description
    }
}`;

const zip = await sanityClient.fetch<SanityDocument>(ZIP_BY_SLUG_QUERY);
if (!zip) {
    throw new Error(`Zip entry not found for slug: ${slug}`);
}
const portableText = zip.body;

const canonicalURL = new URL(`/blog/zips/${slug}`, Astro.site).href;

---

<SiteLayout pageTitle={zip.title} canonicalURL={canonicalURL}>
    <main class="max-w-3xl mx-auto px-6 pb-24">
        <header class="pt-16 pb-12">
            <h1 class="text-4xl md:text-5xl font-bold mb-4 text-brand-orange">
                {zip.title}
            </h1>
            <AuthorLayout publishedAt={zip.publishedAt} />
            <div class="text-brand-gray mt-6">
                {zip.excerpt}
            </div>
        </header>

        <article class="content text-brand-accent">
            <PortableText value={portableText} components={components} />
        </article>

    {zip.tags && zip.tags.length > 0 && (
        <div class="mt-8 pt-6">
            <h3 class="text-xs font-bold uppercase tracking-widest text-brand-gray mb-4">Tags</h3>
            <div class="flex flex-wrap gap-2">
                {zip.tags.map((tag) => {
                    const colors = getTagColorClasses(tag.color);
                    return (
                        <a
                            href={`/blog/tags/${tag.slug}`}
                            class={`inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium ${colors.bg} ${colors.text} ${colors.hover} transition-colors duration-200`}
                            title={tag.description || `Ver todos los posts sobre ${tag.name}`}
                        >
                            #{tag.name}
                        </a>
                    );
                })}
            </div>
        </div>
    )}


    </main>
</SiteLayout>
