---
import ZipsCard from '../../../components/ZipsCard.astro';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import Icon from '../../../components/Icon.astro';

import { sanityClient } from "sanity:client";
import type { SanityDocument } from "@sanity/client";

const ZIPS_QUERY = `*[contentType == "zip"] | order(publishedAt desc) {
  _id,
  title,
  slug,
  excerpt
}`;

const zipsEntries = await sanityClient.fetch<SanityDocument[]>(ZIPS_QUERY);

---

<SiteLayout pageTitle="Zips">
    <main class="max-w-4xl mx-auto px-6 pb-24">
        <h1 class="text-4xl md:text-5xl font-bold mb-5 text-brand-orange">
            Zips <Icon name="lightning" size={36} className="inline-block align-middle ml-2" />
        </h1>

        <p class="text-lg mb-14 leading-loose">¡Bienvenido/a a <span class="font-bold">Zips</span>! Aquí encontrarás lecturas rápidas de índole técnica. La idea es que te lleves un aprendizaje, encuentres recursos, o simplemente te diviertas en lecturas breves de pocos minutos.</p>

        <div class="grid lg:grid-cols-2 gap-6">
            {
            zipsEntries.map((zip) => (
                <div>
                    <ZipsCard zip={zip} />
                </div>
            ))
        }
    </main>
</SiteLayout>
