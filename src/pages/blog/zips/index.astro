---
import ZipsCard from '../../../components/ZipsCard.astro';
import SiteLayout from '../../../layouts/SiteLayout.astro';

import { sanityClient } from "sanity:client";
import type { SanityDocument } from "@sanity/client";

const ZIPS_QUERY = `*[contentType == "zip"] | order(publishedAt desc) {
  _id,
  title,
  slug,
  excerpt
}`;

const zipsEntries = await sanityClient.fetch<SanityDocument[]>(ZIPS_QUERY);

---

<SiteLayout pageTitle="Zips">
    <main class="max-w-3xl mx-auto px-6 pb-24">
        <h1 class="text-4xl md:text-5xl font-bold mb-5 text-brand-orange">Zips ⚡​</h1>

        <p class="text-lg mb-14 leading-loose text-brand-gray">¡Bienvenido/a a <span class="font-bold">Zips</span>! Aquí encontrarás lecturas rápidas sobre tecnología, programación, etc. La idea es que te lleves un aprendizaje, una reflexión, encuentres recursos, o simplemente te diviertas en lecturas breves de pocos minutos.</p>

        <div class="grid lg:grid-cols-2 gap-4">
            {
            zipsEntries.map((zip) => (
                <div class="min-h-[120px]">
                    <ZipsCard zip={zip} />
                </div>
            ))
        }
    </main>
</SiteLayout>
