---
import Social from '../../components/Social.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Separator from '../../components/Separator.astro';
import PostDescription from '../../components/PostDescription.astro';

import { sanityClient } from "sanity:client";
import type { SanityDocument } from "@sanity/client";

const FEATURED_POSTS_QUERY = `*[
	contentType == "post" && featured == true
]|order(publishedAt desc){_id, title, slug, excerpt, publishedAt}
`;

const featured_posts = await sanityClient.fetch<SanityDocument[]>(FEATURED_POSTS_QUERY);

const LATEST_POSTS_QUERY = `*[
    _type == "post"
]|order(publishedAt desc)[0...5]{_id, title, slug, excerpt, publishedAt}
`;
const latest_posts = await sanityClient.fetch<SanityDocument[]>(LATEST_POSTS_QUERY);

const pageTitle = 'Blog'
---

<BaseLayout pageTitle={pageTitle}>
	<main>
		<div class="flex flex-col items-center ">
			<div class="w-64 lg:w-96 lg:me-5 h-64 lg:h-96 bg-cover bg-center bg-no-repeat rounded-full mb-5"
				style="background-image: url('https://res.cloudinary.com/dwczjy8e4/image/upload/v1729968282/blog/esvdev_lofi_blog_mx4t7x.png')">
			</div>

			<div>
				<h1 class="text-4xl font-bold block mb-3">Blog</h1>

				<p class="text-lg mb-5 leading-loose">
				    Este es el hub técnico de <span class="font-bold italic">El Ingeniero Consciente</span>.
				</p>

				<p class="text-lg mb-5 leading-loose">
    				Aquí publico contenido estrictamente técnico: Data Engineering, arquitectura AWS y conceptos aplicados al software. Sin reflexión extensa ni desarrollo personal. Este espacio está dedicado a lo concreto, lo ejecutable y lo que puede ponerse en práctica.
				</p>

				<p class="text-lg mb-5 leading-loose">
				Encontrarás dos formatos:
    				<ul>
        				<li> <a href="/blog/page1">Posts</a> en profundidad</li>
        				<li> <a href="/blog/zips">Zips</a> , ideas técnicas comprimidas a lo esencial</li>
    				</ul>
				</p>

				<p class="text-lg mb-5 leading-loose">
    				Cada nuevo artículo es anunciado en la newsletter, dentro de las secciones <span class="font-bold italic">Taller de Datos</span> y <span class="font-bold italic">La Senda del Nubearquitecto</span>.
				</p>

				<p class="text-lg mb-5 leading-loose">
    				Si solo te interesa lo técnico, la newsletter funciona como un sistema de notificaciones para no perderte nuevas publicaciones.
				</p>

				<p class="text-lg mb-5 leading-loose">
    				Si además te interesa crecer como profesional —criterio, mentalidad y carrera— esa conversación también vive allí.
				</p>

			</div>
		</div>

		<Separator />

		<!-- Featured -->
		<div class="flex flex-col">
			<h1 class="font-bold text-3xl block mb-5">Destacados</h1>

			<div>
				{
                    featured_posts.map((post) => (
						<PostDescription
							postURL={`/blog/${post.slug.current}`}
							postTitle={post.title}
							postDate={post.publishedAt}
							postDescription={post.excerpt}
						/>
                    ))

                }
			</div>
		</div>

		<Separator />

		<!-- Latest posts -->
		<div class="flex flex-col">
			<h1 class="font-bold text-3xl block mb-5">Ultimos posts</h1>

			<div>
				{
                    latest_posts.map((post) => (
						<PostDescription
							postURL={`/blog/${post.slug.current}`}
							postTitle={post.title}
							postDate={post.publishedAt}
							postDescription={post.excerpt}
						/>
                    ))

                }
			</div>

			<div class="flex justify-center text-bold">
				<a href="/blog/page1" class="text-white hover:text-orange-500">
				Todos los posts
				<i class='bx bx-right-arrow-alt'></i>
				</a>
			</div>
		</div>
	</main>
</BaseLayout>
